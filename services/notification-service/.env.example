PORT=3004
MONGO_URI=mongodb://mongodb:27017/nexship-notifications
KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=notification-service-group

# Nodemailer SMTP config — use any SMTP provider (Gmail, Mailgun, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="NexShip <no-reply@nexship.com>"
